<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:main="using:LRReader.Avalonia.Views.Main"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="LRReader.Avalonia.Views.Root">
    <ui:FAFrame x:Name="FrameContent" x:FieldModifier="public" IsNavigationStackEnabled="False" NavigationFailed="FrameContent_NavigationFailed" />
</UserControl>
