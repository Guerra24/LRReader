<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LRReader.Avalonia"
             xmlns:sty="using:FluentAvalonia.Styling"
             Name="LRReader"
             x:Class="LRReader.Avalonia.App">
    <Application.Styles>
        <sty:FluentAvaloniaTheme PreferUserAccentColor="True" />
    </Application.Styles>
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Resources/Converters.axaml" />
                <ResourceInclude Source="/Resources/Templates.axaml" />
                <ResourceInclude Source="/Resources/AvaloniaTemplates.axaml" />
                <ResourceInclude Source="/Resources/PagerControl.axaml" />
                <ResourceInclude Source="/Resources/ThemeDictionary.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <vm:ViewModelLocator x:Key="Locator" />
            <SolidColorBrush x:Key="CustomReaderBackground" Color="Black" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
